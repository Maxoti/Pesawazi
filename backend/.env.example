# --- Server ---
PORT=3000
# Comma-separated list of origins allowed to call the read API (your dashboard frontend)
CORS_ORIGIN=http://localhost:3001

# --- Database (Neon Postgres, same pattern as ElimuPay) ---
DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require

# --- API key guard (single-tenant MVP auth for the dashboard's read endpoints) ---
DASHBOARD_API_KEY=replace-with-a-long-random-string

# --- Daraja credentials for THIS pilot business only ---
# From https://developer.safaricom.co.ke -> your app -> Keys
DARAJA_CONSUMER_KEY=
DARAJA_CONSUMER_SECRET=
DARAJA_ENV=sandbox
# sandbox -> https://sandbox.safaricom.co.ke
# production -> https://api.safaricom.co.ke

# Shortcode being onboarded.
# IMPORTANT: confirm with the business whether this is a PAYBILL or a BUY GOODS (TILL).
# Paybill -> CustomerPayBillOnline transactions
# Till    -> CustomerBuyGoodsOnline transactions
DARAJA_SHORTCODE=
DARAJA_SHORTCODE_TYPE=paybill

# Public HTTPS base URL Safaricom will call (ngrok URL in local dev, real domain in prod)
DARAJA_CALLBACK_BASE_URL=https://your-public-url.example.com

# Only required if you're also doing STK Push from this backend (optional for MVP;
# the pilot dashboard mainly needs Confirmation/Validation for C2B, not STK)
DARAJA_PASSKEY=
